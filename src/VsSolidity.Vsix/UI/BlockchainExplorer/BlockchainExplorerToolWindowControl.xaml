<UserControl x:Class="VsSolidity.UI.BlockchainExplorerToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:VsSolidityui="clr-namespace:VsSolidity.UI;assembly="
             xmlns:vm="clr-namespace:VsSolidity.UI.ViewModel;assembly=" 
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300"
             Name="BlockchainExplorerToolWindow"
>
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="{x:Static VsSolidityui:VSTheme.ApplicationThemeGuess}" />
                <ui:ControlsDictionary />
                <ResourceDictionary Source="BlockchainExplorerTreeResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <!-- The view model that provides the data for the trees -->
            <vm:BlockchainViewModel x:Key="Blockchains" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Vertical" Grid.Row="0">
            <VsSolidityui:BlockchainExplorerTree x:Name="BlockchainExplorerTree"
                    Items="{Binding Source={StaticResource Blockchains}, Path=Objects}"
                    TreeNodeStyle="{StaticResource TreeViewItemStyle}"
                    TreeStyle="{StaticResource TreeViewStyle}"
                    NodeSortDescriptions="{StaticResource AscendingNames}"
                    SelectNodesOnRightClick="True"
                    SelectedItemChanged="OnSelectedItemChanged"
                    MouseDoubleClick="OnMouseDoubleClick"
                    IsLazyLoading="False"
                    Margin="0,0,0,10" />
        </StackPanel>
        <ContentPresenter x:Name="RootContentDialog" Grid.Row="0"/>
    </Grid>

    <UserControl.CommandBindings>
        <!-- bindings for context menu commands -->
        <CommandBinding Command="{x:Static VsSolidityui:BlockchainExplorerTree.NewNetworkCmd}" Executed="NewNetworkCmd_Executed" />
        <CommandBinding Command="{x:Static VsSolidityui:BlockchainExplorerTree.DeleteNetworkCmd}" Executed="DeleteNetworkCmd_Executed" CanExecute="DeleteNetworkCmd_CanExecute" />
        <CommandBinding Command="{x:Static VsSolidityui:BlockchainExplorerTree.NewFolderCmd}" Executed="NewFolderCmd_Executed" />
        <CommandBinding Command="{x:Static VsSolidityui:BlockchainExplorerTree.PropertiesCmd}" Executed="PropertiesCmd_Executed" />
        <CommandBinding Command="{x:Static VsSolidityui:BlockchainExplorerTree.DeleteFolderCmd}" Executed="DeleteFolderCmd_Executed" />
        <CommandBinding Command="{x:Static VsSolidityui:BlockchainExplorerTree.NewEndpointCmd}" Executed="NewEndpointCmd_Executed" />
        <CommandBinding Command="{x:Static VsSolidityui:BlockchainExplorerTree.DeleteEndpointCmd}" Executed="DeleteEndpointCmd_Executed" CanExecute="DeleteEndpointCmd_CanExecute" />
        <CommandBinding Command="{x:Static VsSolidityui:BlockchainExplorerTree.EditAccountCmd}" Executed="EditAccountCmd_Executed" />
        <CommandBinding Command="{x:Static VsSolidityui:BlockchainExplorerTree.NewDeployProfileCmd}" Executed="NewDeployProfileCmd_Executed" />
        <CommandBinding Command="{x:Static VsSolidityui:BlockchainExplorerTree.DeleteDeployProfileCmd}" Executed="DeleteDeployProfileCmd_Executed" />
        <CommandBinding Command="{x:Static VsSolidityui:BlockchainExplorerTree.EditDeployProfileCmd}" Executed="EditDeployProfileCmd_Executed" />
        <CommandBinding Command="{x:Static VsSolidityui:BlockchainExplorerTree.CopyAccountAddressCmd}" Executed="CopyAccountAddressCmd_Executed" />
        <CommandBinding Command="{x:Static VsSolidityui:BlockchainExplorerTree.NewAccountCmd}" Executed="NewAccountCmd_Executed" />
        <CommandBinding Command="{x:Static VsSolidityui:BlockchainExplorerTree.DeleteAccountCmd}" Executed="DeleteAccountCmd_Executed" />
        <CommandBinding Command="{x:Static VsSolidityui:BlockchainExplorerTree.EditContractCmd}" Executed="EditContractCmd_Executed" />
        <CommandBinding Command="{x:Static VsSolidityui:BlockchainExplorerTree.DeleteContractCmd}" Executed="DeleteContractCmd_Executed" />
        <CommandBinding Command="{x:Static VsSolidityui:BlockchainExplorerTree.RunContractCmd}" Executed="RunContractCmd_Executed" />
    </UserControl.CommandBindings>

</UserControl>
