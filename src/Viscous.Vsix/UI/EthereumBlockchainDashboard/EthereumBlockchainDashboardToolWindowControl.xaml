<UserControl x:Class="Viscous.UI.ViscousBlockchainDashboardToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vsethexp="clr-namespace:Viscous.Ethereum.Explorers;assembly=Viscous.Ethereum"
             xmlns:Viscousui="clr-namespace:Viscous.UI;assembly="
   
             d:DesignHeight="800" 
             d:DesignWidth="800"
             ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
             ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
             Foreground="{DynamicResource TextFillColorPrimaryBrush}"
             
             Width="Auto"
             Height="Auto"
             Name="MyToolWindow"
             Loaded="UserControl_Loaded">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ui:NavigationView Name="DasboardNavigationView" MinHeight="800" Margin="0" IsBackButtonVisible="Auto" IsPaneToggleVisible="True" PaneDisplayMode="Top" >
        <ui:NavigationView.MenuItems>
            <ui:NavigationViewItem Content="Home" Icon="{ui:SymbolIcon Home24}" TargetPageType="{x:Type Viscousui:ViscousBlockchainHomeUserControl}"  />
            <ui:NavigationViewItem Content="Transactions" Icon="{ui:SymbolIcon AppFolder24}" TargetPageType="{x:Type Viscousui:ViscousBlockchainDashboardTransactionsUserControl}" />
            <ui:NavigationViewItem Content="Blocks" Icon="{ui:SymbolIcon BezierCurveSquare20}" TargetPageType="{x:Type Viscousui:ViscousBlockchainDashboardToolWindowControl}" />
            <ui:NavigationViewItem Content="Accounts" Icon="{ui:SymbolIcon Library24}" TargetPageType="{x:Type Viscousui:ViscousBlockchainDashboardToolWindowControl}" />
            <ui:NavigationViewItem Content="Contracts" Icon="{ui:SymbolIcon Library24}" TargetPageType="{x:Type Viscousui:ViscousBlockchainDashboardToolWindowControl}" />
        </ui:NavigationView.MenuItems>
        <ui:NavigationView.FooterMenuItems>
            <ui:NavigationViewItem Icon="{ui:SymbolIcon Settings24}" TargetPageType="{x:Type Viscousui:ViscousBlockchainDashboardToolWindowControl}" />
        </ui:NavigationView.FooterMenuItems>
        <ui:NavigationView.AutoSuggestBox>
            <ui:AutoSuggestBox MinWidth="250" Margin="0" PlaceholderText="Search" />
        </ui:NavigationView.AutoSuggestBox>
        <ui:NavigationView.Header>
            <Border Height="200" CornerRadius="8">
                <Border CornerRadius="8">
                    <Border.Background>
                        <RadialGradientBrush>
                            <GradientStop Offset="1" Color="#101112" />
                            <GradientStop Offset="0" Color="#000000" />
                        </RadialGradientBrush>
                    </Border.Background>
                    <ui:Image Source="{x:Static Viscousui:ViscousBlockchainDashboardToolWindowControl.DashboardHeaderImage}" Stretch="UniformToFill" />
                </Border>
            </Border>
        </ui:NavigationView.Header>
    </ui:NavigationView>
</UserControl>
